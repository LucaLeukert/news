{
  "name": "coverage-lens",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "bun --env-file ./.env turbo dev --filter=@news/api --filter=@news/web --filter=@news/admin --filter=@news/convex --ui tui",
    "dev:all": "bun --env-file ./.env turbo dev",
    "build": "turbo build",
    "test": "vitest run",
    "typecheck": "turbo typecheck",
    "lint": "oxlint . && biome check .",
    "format": "biome format --write .",
    "effect:lsp": "effect-language-service",
    "db:generate": "bun --env-file ./.env --filter @news/db drizzle-kit generate",
    "db:migrate": "bun --env-file ./.env --filter @news/db drizzle-kit migrate",
    "db:studio": "bun --env-file ./.env --filter @news/db drizzle-kit studio",
    "reset:local-state": "bash ./scripts/reset-local-state.sh",
    "api:prepare-local": "node ./scripts/write-api-dev-vars.mjs",
    "api:dev": "bun --filter @news/api dev",
    "api:dev:lan": "bun --filter @news/api dev:lan",
    "ai:runner": "bun --filter @news/ai-runner dev",
    "crawler:seed-and-ingest": "bun --filter @news/crawler dev seed-and-ingest",
    "crawler:reingest-failed-verification": "bun --filter @news/crawler dev reingest-failed-verification",
    "remote:ai:sync": "bash ./scripts/sync-remote-ai-runner.sh",
    "remote:ai:start": "bash ./scripts/start-remote-ai-runner.sh",
    "remote:ai:start:detached": "bash ./scripts/start-remote-ai-runner-detached.sh",
    "dev:local": "bash ./scripts/dev-local.sh"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@clerk/backend": "^3.2.13",
    "@clerk/nextjs": "^7.2.3",
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "ai": "^6.0.168",
    "convex": "^1.36.0",
    "effect": "4.0.0-beta.56"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@effect/language-service": "^0.85.1",
    "@types/node": "^22.14.1",
    "oxlint": "^1.61.0",
    "turbo": "^2.5.0",
    "typescript": "5.8.3",
    "vitest": "^3.1.1",
    "zod": "^3.24.3"
  },
  "workspaces": ["apps/*", "services/*", "packages/*"]
}
