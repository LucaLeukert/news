{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "node_modules/**",
    ".turbo/**",
    "**/.turbo/**",
    ".next/**",
    "**/.next/**",
    "convex/_generated/**",
    "dist/**",
    "**/.wrangler/**",
    "bun.lock",
    "apps/*/next-env.d.ts"
  ],
  "typescript": {
    "allowNamespaces": false
  },
  "rules": {
    "typescript-eslint/triple-slash-reference": "off"
  }
}
